<div class="content">
  <h1>Lógica: El Corazón de la Computación</h1>
</div>
<style>
  .content {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: #ffffff;
    font-family:
      "Inter",
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    z-index: 1000;
    animation: fadeInUp 1s ease-out forwards;
  }
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translate(-50%, -40%);
    }
    to {
      opacity: 1;
      transform: translate(-50%, -190px);
    }
  }
  h1 {
    font-size: 3rem;
    font-weight: 300;
    margin: 0;
    color: #ab2ef3;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }
</style>
<style>
  @keyframes fadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }
</style>
